ANTHROPIC_API_KEY=sk-ant-paste-your-key-here

# Fitbit / Fitbit Air (Today's vitals → Fitbit → Connect Fitbit). See FITBIT_SETUP.md.
# As of 2026 this goes through the GOOGLE HEALTH API, not dev.fitbit.com.
# Create a Google Cloud OAuth client (Web application) with Authorized redirect URI
#   https://YOUR-APP.vercel.app/api/fitbit/callback
# These hold the Google Cloud client ID/secret (names keep the FITBIT_ prefix).
FITBIT_CLIENT_ID=
FITBIT_CLIENT_SECRET=

# Supabase (cloud sync via db.js → /api/config). Anon key is public-safe.
SUPABASE_URL=
SUPABASE_ANON_KEY=
